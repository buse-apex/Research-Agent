# ============================================
# APEX RESEARCH AGENT · ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for local dev.
# In Vercel: add these in Project Settings → Environment Variables.

# === NextAuth ===
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here-32-chars-min
NEXTAUTH_URL=http://localhost:3000

# === Google OAuth (same Google Cloud project as the Proof Finder works fine) ===
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#                           https://your-domain.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Access allowlist (Proof Finder pattern) ===
# Grant access by listing franchisee emails (comma-separated), by domain, or both.
# At least one must be set or all sign-ins are denied.
ALLOWED_EMAILS=franchisee1@gmail.com,franchisee2@theirco.com
ALLOWED_DOMAIN=apexleadershipco.com

# === Admin Access ===
# Comma-separated emails who can access /admin
ADMIN_EMAILS=buse@apexleadershipco.com

# === Anthropic API ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Vercel Postgres ===
# Auto-injected when you connect a Postgres database in Vercel.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# === PostHog analytics (per-franchisee usage tracking) ===
# Project API key from your research-agent PostHog project (starts with phc_).
# This is a public/browser key by design; safe to expose to the client.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Apify (optional social media deep dive) ===
# Personal API token from Apify Console -> Settings -> Integrations.
# If unset, the social checkbox degrades gracefully (research runs without it).
APIFY_TOKEN=apify_api_your_token_here

# === Serper (real Google results layer) ===
# API key from serper.dev (free tier covers ~2,500 searches). If unset, the
# Google layer silently skips and research runs on the built-in search only.
SERPER_API_KEY=your_serper_key_here
